{$ONE_DOMAIN} {
    encode zstd gzip

    request_body {
        max_size 12MB
    }

    reverse_proxy /api/* server:8080 {
        health_uri /api/health
        health_interval 30s
        health_timeout 3s
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "no-referrer"
        -Server
    }
}
