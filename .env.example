# 公网域名（已解析到阿里云 ECS）
ONE_DOMAIN=one.example.com

# MySQL：请替换为强随机密码
MYSQL_DATABASE=one
MYSQL_USER=one
MYSQL_PASSWORD=replace-with-a-long-random-password
MYSQL_ROOT_PASSWORD=replace-with-another-long-random-password
DB_POOL_MAX_SIZE=10

# 登录与会话
ONE_TOKEN_SECRET=replace-with-at-least-32-random-characters
ONE_TOKEN_TTL=PT720H
WECHAT_MOCK_ENABLED=false
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# Qwen3.6 多模态识图
QWEN_ENABLED=true
DASHSCOPE_API_KEY=
DASHSCOPE_WORKSPACE_ID=
QWEN_VISION_MODEL=qwen3.6-flash
# 可选：若阿里云控制台提供完整兼容模式地址，可直接覆盖
QWEN_BASE_URL=
QWEN_TIMEOUT=PT30S

# 媒体。域名必须与 ONE_DOMAIN 一致
ONE_MEDIA_BASE_URL=https://one.example.com/api/media/public
ONE_MAX_IMAGE_BYTES=10485760
