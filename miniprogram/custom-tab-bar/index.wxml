<view class="tab-shell">
  <view wx:for="{{list}}" wx:key="pagePath" class="tab {{selected === index ? 'active' : ''}}" data-index="{{index}}" bindtap="switchTab">
    <view class="symbol">{{item.symbol}}<view wx:if="{{selected === index}}" class="pulse"></view></view>
    <text>{{item.text}}</text>
  </view>
</view>
