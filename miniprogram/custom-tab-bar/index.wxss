.tab-shell {
  position: fixed;
  z-index: 100;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  height: 112rpx;
  padding: 8rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 42rpx;
  background: rgba(255, 255, 255, 0.86);
  box-shadow: 0 16rpx 54rpx rgba(65, 49, 47, 0.1);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.tab-item {
  position: relative;
  width: 132rpx;
  height: 92rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 2rpx;
  color: #9A8E8A;
  font-size: 20rpx;
}

.tab-item--active { color: #F8A4A8; }

.tab-icon {
  height: 44rpx;
  font-family: "SF Pro Text", sans-serif;
  font-size: 38rpx;
  font-weight: 400;
  line-height: 42rpx;
}

.breathing-dot {
  position: absolute;
  bottom: 2rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #F8A4A8;
  box-shadow: 0 0 18rpx #F8A4A8;
  animation: breathe 1.8s ease-in-out infinite;
}

@keyframes breathe {
  0%, 100% { transform: scale(0.75); opacity: 0.5; }
  50% { transform: scale(1.25); opacity: 1; }
}
