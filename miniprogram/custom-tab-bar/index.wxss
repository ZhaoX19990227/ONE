.tab-shell { position:fixed; z-index:99; left:24rpx; right:24rpx; bottom:calc(env(safe-area-inset-bottom) + 18rpx); height:116rpx; padding:0 22rpx; display:flex; justify-content:space-around; align-items:center; border-radius:38rpx; background:rgba(255,255,255,.88); border:1rpx solid rgba(255,255,255,.7); box-shadow:0 18rpx 60rpx rgba(45,42,38,.13); backdrop-filter:blur(20px); }
.tab { width:150rpx; height:92rpx; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:4rpx; color:#9A8E8A; font-size:21rpx; }
.symbol { font-size:37rpx; line-height:42rpx; position:relative; font-weight:300; }
.active { color:#F8A4A8; }
.pulse { position:absolute; width:7rpx; height:7rpx; border-radius:50%; background:#7FC2C9; right:-12rpx; bottom:3rpx; animation:breathe 1.8s ease-in-out infinite; }
@keyframes breathe { 0%,100%{opacity:.3;transform:scale(.7)} 50%{opacity:1;transform:scale(1.35)} }
