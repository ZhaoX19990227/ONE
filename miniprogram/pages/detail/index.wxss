.detail-page { min-height: 100vh; padding-bottom: calc(150rpx + env(safe-area-inset-bottom)); background: #FCF9F8; }
.hero { position: relative; height: 44vh; min-height: 620rpx; overflow: hidden; }
.cover--blush { background: linear-gradient(145deg, #F8C0C2, #E8D1C9 55%, #B98F8B); }
.cover--mist { background: linear-gradient(145deg, #9FD0D3, #B8CACD 55%, #71939B); }
.cover--dusk { background: linear-gradient(145deg, #B6A8BD, #D6BFC4 48%, #A2737D); }
.cover--sage { background: linear-gradient(145deg, #B7C5B2, #D7CEB8 55%, #9D7B67); }
.hero-ring { position: absolute; border: 3rpx solid rgba(255,255,255,.42); border-radius: 50%; }
.hero-ring--one { width: 470rpx; height: 470rpx; top: 60rpx; right: -150rpx; }
.hero-ring--two { width: 300rpx; height: 300rpx; top: 170rpx; right: 160rpx; }
.hero-shade { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(35,28,27,.02) 30%, rgba(35,28,27,.62) 100%); }
.detail-nav { position: relative; z-index: 3; padding-left: 28rpx; padding-right: 28rpx; display: flex; justify-content: space-between; }
.nav-circle { width: 72rpx; height: 72rpx; display: flex; align-items: center; justify-content: center; border: 1rpx solid rgba(255,255,255,.5); border-radius: 50%; color: #fff; background: rgba(45,42,38,.16); backdrop-filter: blur(14px); font-family: serif; font-size: 48rpx; line-height: 1; }
.share-circle { font-size: 32rpx; }
.hero-copy { position: absolute; z-index: 2; left: 38rpx; right: 38rpx; bottom: 92rpx; display: flex; flex-direction: column; color: #fff; }
.hero-eyebrow { margin-bottom: 16rpx; font-family: "SF Pro Text", sans-serif; font-size: 20rpx; letter-spacing: 5rpx; opacity: .8; }
.hero-title { max-width: 650rpx; font-size: 50rpx; font-weight: 500; line-height: 1.25; }
.hero-tags { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 24rpx; }
.hero-tags text { padding: 9rpx 17rpx; border: 1rpx solid rgba(255,255,255,.35); border-radius: 24rpx; background: rgba(255,255,255,.13); font-size: 19rpx; backdrop-filter: blur(10px); }

.content-wrap { position: relative; z-index: 4; margin-top: -55rpx; padding: 0 30rpx; }
.key-card { padding: 30rpx 30rpx; border-radius: 30rpx; }
.key-item { display: grid; grid-template-columns: 64rpx 1fr; align-items: center; padding: 18rpx 0; }
.key-item + .key-item { border-top: 1rpx solid rgba(154,142,138,.12); }
.key-icon { width: 46rpx; height: 46rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; color: #F08F95; background: rgba(248,164,168,.13); font-family: "SF Pro Text", sans-serif; font-size: 25rpx; }
.key-item > view:last-child { display: flex; flex-direction: column; gap: 6rpx; }
.key-label { color: #9A8E8A; font-size: 19rpx; }
.key-value { font-size: 26rpx; line-height: 1.5; }
.detail-section { padding: 58rpx 8rpx 12rpx; }
.section-kicker { display: block; margin-bottom: 10rpx; color: #7FC2C9; font-size: 17rpx; letter-spacing: 4rpx; }
.section-title { font-size: 34rpx; font-weight: 500; }
.description { display: block; margin-top: 22rpx; color: #655D59; font-size: 27rpx; line-height: 1.8; }
.attribute-cloud { display: flex; flex-wrap: wrap; gap: 14rpx; margin-top: 26rpx; }
.attribute-pill { display: flex; flex-direction: column; gap: 5rpx; min-width: 200rpx; padding: 18rpx 22rpx; border-radius: 22rpx; background: rgba(127,194,201,.1); color: #496F73; font-size: 22rpx; }
.attribute-key { color: #9A8E8A; font-size: 17rpx; }
.section-heading-row { display: flex; justify-content: space-between; align-items: baseline; }
.member-count { color: #F08F95; font-family: "SF Pro Text", sans-serif; font-size: 24rpx; }
.participants { position: relative; height: 86rpx; margin-top: 28rpx; }
.participant-avatar { position: absolute; top: 0; width: 76rpx; height: 76rpx; display: flex; align-items: center; justify-content: center; border: 5rpx solid #FCF9F8; border-radius: 50%; color: #fff; background: linear-gradient(145deg,#B6A8BD,#8DAEB2); font-size: 24rpx; }
.participant-more { color: #806F69; background: #EDE4E1; }
.host-card { margin: 46rpx 0 22rpx; padding: 25rpx; border-radius: 28rpx; display: flex; align-items: center; }
.host-avatar-large { width: 82rpx; height: 82rpx; display: flex; align-items: center; justify-content: center; border: 3rpx solid rgba(248,164,168,.55); border-radius: 50%; color: #fff; background: #A9A0AA; }
.host-copy { flex: 1; margin-left: 20rpx; display: flex; flex-direction: column; gap: 7rpx; color: #9A8E8A; font-size: 20rpx; }
.host-name { color: #2D2A26; font-size: 27rpx; }
.host-badge { padding: 9rpx 16rpx; border-radius: 18rpx; color: #F08F95; background: rgba(248,164,168,.12); font-size: 18rpx; }
.safety-note { padding: 32rpx 12rpx 42rpx; display: flex; gap: 14rpx; color: #9A8E8A; font-size: 20rpx; line-height: 1.7; }
.safety-note > text:first-child { color: #7FC2C9; }

.bottom-action { position: fixed; z-index: 20; left: 0; right: 0; bottom: 0; min-height: 126rpx; padding: 18rpx 30rpx calc(18rpx + env(safe-area-inset-bottom)); display: flex; align-items: center; gap: 30rpx; border-top: 1rpx solid rgba(255,255,255,.8); background: rgba(252,249,248,.88); box-shadow: 0 -14rpx 46rpx rgba(59,45,44,.06); backdrop-filter: blur(20px); }
.deposit-copy { width: 190rpx; display: flex; flex-direction: column; gap: 5rpx; }
.deposit-label { color: #9A8E8A; font-size: 19rpx; }
.deposit-value { font-family: "SF Pro Text", sans-serif; font-size: 34rpx; font-weight: 500; }
.join-button { flex: 1; height: 92rpx; border-radius: 46rpx; color: #fff; background: linear-gradient(135deg,#F8A4A8,#E4C7C8); box-shadow: 0 14rpx 30rpx rgba(248,164,168,.28); font-size: 29rpx; transition: transform 150ms ease; }
.join-button:active { transform: scale(.96); }
.joined-button { background: linear-gradient(135deg,#7FC2C9,#A7CED1); }
.detail-loading { min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 28rpx; color: #9A8E8A; }
