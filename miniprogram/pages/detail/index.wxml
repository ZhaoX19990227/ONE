<view class="detail-page" wx:if="{{loaded}}">
  <view class="hero cover--{{activity.theme}}">
    <view class="hero-ring hero-ring--one"></view>
    <view class="hero-ring hero-ring--two"></view>
    <view class="hero-shade"></view>
    <view class="detail-nav safe-top">
      <view class="nav-circle" bindtap="goBack">‹</view>
      <view class="nav-circle share-circle" bindtap="share"><text>↗</text></view>
    </view>
    <view class="hero-copy">
      <text class="hero-eyebrow">{{activity.mode === 'ONLINE' ? 'ONLINE SIGNAL' : activity.district}}</text>
      <text class="hero-title">{{activity.title}}</text>
      <view class="hero-tags"><text wx:for="{{activity.tags}}" wx:key="*this">{{item}}</text></view>
    </view>
  </view>

  <view class="content-wrap">
    <view class="key-card glass-card">
      <view class="key-item"><view class="key-icon">◷</view><view><text class="key-label">时间</text><text class="key-value">{{activity.displayTime}}</text></view></view>
      <view class="key-item"><view class="key-icon">⌖</view><view><text class="key-label">地点</text><text class="key-value">{{activity.address || activity.district}}</text></view></view>
      <view class="key-item"><view class="key-icon">◌</view><view><text class="key-label">费用</text><text class="key-value">{{activity.feeFen > 0 ? '活动费以现场说明为准' : '免费活动'}}</text></view></view>
    </view>

    <view class="detail-section">
      <text class="section-kicker">ABOUT THIS MOMENT</text>
      <text class="section-title">关于这场相遇</text>
      <text class="description">{{activity.description}}</text>
    </view>

    <view class="detail-section attribute-section">
      <text class="section-title">合拍条件</text>
      <view class="attribute-cloud">
        <view wx:for="{{activity.attributes}}" wx:key="key" class="attribute-pill">
          <text class="attribute-key">{{key}}</text><text>{{item}}</text>
        </view>
      </view>
    </view>

    <view class="detail-section">
      <view class="section-heading-row">
        <text class="section-title">已经同频的人</text>
        <text class="member-count">{{activity.joinedCount}} / {{activity.capacity}}</text>
      </view>
      <view class="participants">
        <view wx:for="{{activity.participants}}" wx:key="*this" wx:if="{{index < 5}}" class="participant-avatar" style="left: {{index * 58}}rpx; z-index: {{10-index}}">{{item}}</view>
        <view wx:if="{{activity.joinedCount > 5}}" class="participant-avatar participant-more" style="left: 290rpx">+{{activity.joinedCount - 5}}</view>
      </view>
    </view>

    <view class="host-card glass-card">
      <view class="host-avatar-large">{{activity.host.avatar}}</view>
      <view class="host-copy"><text class="host-name">{{activity.host.nickname}}</text><text>认真完成过 {{activity.host.completedCount}} 场活动</text></view>
      <view class="host-badge">发起人</view>
    </view>

    <view class="safety-note"><text>◉</text><text>详细位置仅对报名成功的人可见。遇到不适时，请及时退出并举报。</text></view>
  </view>

  <view class="bottom-action">
    <view class="deposit-copy">
      <text class="deposit-label">🕊️ 鸽子金</text>
      <text class="deposit-value">{{activity.depositFen > 0 ? '¥' + feeYuan : '无需'}}</text>
    </view>
    <button wx:if="{{!activity.isJoined}}" class="join-button" loading="{{joining}}" bindtap="join">立即加入</button>
    <button wx:else class="join-button joined-button" bindtap="checkIn">已加入 · 去签到</button>
  </view>
</view>

<view wx:else class="detail-loading"><view class="one-rings"></view><text>正在靠近这场相遇…</text></view>
