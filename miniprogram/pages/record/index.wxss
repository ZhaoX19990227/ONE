.record-page { padding-bottom:90rpx; }.back { width:64rpx; height:64rpx; border-radius:50%; background:rgba(255,255,255,.55); display:flex; align-items:center; justify-content:center; font-size:50rpx; line-height:55rpx; }.nav-title { font-size:29rpx; font-weight:500; }.nav-side { width:64rpx; color:var(--muted); font-size:19rpx; letter-spacing:2rpx; }
.photo-card { height:410rpx; border-radius:42rpx; margin-top:25rpx; overflow:hidden; position:relative; }.photo-card image { width:100%; height:100%; }.photo-empty { height:100%; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:12rpx; font-size:27rpx; }.camera-ring { width:86rpx; height:86rpx; border:2rpx solid var(--primary); border-radius:50%; display:flex; align-items:center; justify-content:center; color:var(--primary); font-size:45rpx; margin-bottom:6rpx; }.recognizing { position:absolute; inset:0; background:rgba(252,249,248,.88); display:flex; flex-direction:column; align-items:center; justify-content:center; color:#2D2A26; font-size:24rpx; }.recognizing .rings { margin:0 0 28rpx; animation:pulse 1.5s ease-in-out infinite; }@keyframes pulse{50%{transform:scale(1.08);opacity:.7}}
.form-section { margin-top:34rpx; }.candidate-scroll { width:100%; white-space:nowrap; }.candidate-row { display:flex; gap:16rpx; padding:2rpx 4rpx 22rpx; }.vision-chip { display:inline-flex; width:390rpx; min-height:135rpx; box-sizing:border-box; padding:24rpx; border-radius:28rpx; flex-direction:column; white-space:normal; border:2rpx solid transparent; }.vision-chip.selected { border-color:var(--primary); transform:translateY(-3rpx); }.confidence { color:var(--secondary); font-size:20rpx; }.vision-name { font-size:28rpx; margin:9rpx 0 4rpx; }.evidence { font-size:20rpx; line-height:1.45; }
.form-card { margin-top:34rpx; border-radius:38rpx; padding:10rpx 30rpx; }.field { padding:29rpx 0 23rpx; border-bottom:1rpx solid rgba(154,142,138,.18); }.field:last-child{border:0}.label { font-size:22rpx; color:var(--muted); margin-bottom:15rpx; }.label text { opacity:.65; margin-left:8rpx; }.field input { height:54rpx; font-size:29rpx; color:var(--ink); }.field textarea{width:100%;min-height:55rpx;font-size:27rpx;line-height:1.7;color:var(--ink)}.money-input { display:flex; align-items:center; gap:12rpx; font-size:31rpx; color:var(--primary); }.money-input input{flex:1}.option-row { display:flex; flex-wrap:wrap; gap:13rpx; }.option { background:rgba(255,255,255,.5); color:var(--muted); border:1rpx solid rgba(154,142,138,.14); }.option.on { background:rgba(248,164,168,.16); color:var(--ink); border-color:rgba(248,164,168,.28); }.drink-memory{padding:1rpx 28rpx 29rpx;border-radius:34rpx}.drink-memory .section-title{margin-top:28rpx}.sub-title { color:var(--muted); font-size:23rpx; margin:28rpx 0 17rpx; }.sub-title.first{margin-top:0}.stars { display:flex; gap:25rpx; font-size:48rpx; color:rgba(154,142,138,.25); }.stars .lit { color:var(--primary); text-shadow:0 6rpx 18rpx rgba(248,164,168,.3); }.save { margin-top:50rpx; }.save[disabled]{opacity:.72}.toast { position:fixed; z-index:200; left:50%; top:45%; transform:translate(-50%,-50%); width:max-content; max-width:580rpx; box-sizing:border-box; padding:25rpx 38rpx; border-radius:999rpx; background:rgba(45,42,38,.9); color:white; font-size:24rpx; text-align:center; }
