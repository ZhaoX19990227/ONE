<view class="checkin-page">
  <canvas canvas-id="petalCanvas" class="petal-canvas"></canvas>
  <view class="checkin-orb checkin-orb--pink"></view><view class="checkin-orb checkin-orb--blue"></view>
  <view class="success-content {{success ? 'success-content--visible' : ''}}">
    <view class="success-rings"><view></view><view></view><text>✓</text></view>
    <text class="success-kicker">SIGNAL CONNECTED</text>
    <text class="success-title">今日同频成功 ✨</text>
    <text class="success-copy">愿这场相遇轻松、真诚，也保留各自舒服的边界。</text>
    <button class="finish-button" bindtap="finish">回到我的行程</button>
  </view>
</view>
