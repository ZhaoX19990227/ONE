.checkin-page { position: relative; min-height: 100vh; overflow: hidden; background: linear-gradient(155deg,#FCF9F8,#F5E8E7 55%,#E5F0F0); }
.petal-canvas { position: absolute; z-index: 5; inset: 0; width: 100%; height: 100%; pointer-events: none; }
.checkin-orb { position: absolute; border-radius: 50%; filter: blur(8rpx); opacity: .27; }
.checkin-orb--pink { width: 500rpx; height: 500rpx; right: -250rpx; top: -150rpx; background: #F8A4A8; }
.checkin-orb--blue { width: 420rpx; height: 420rpx; left: -220rpx; bottom: -140rpx; background: #7FC2C9; }
.success-content { position: relative; z-index: 3; min-height: 100vh; padding: 0 76rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; opacity: 0; transform: translateY(30rpx); transition: all 600ms cubic-bezier(.22,.8,.28,1); }
.success-content--visible { opacity: 1; transform: translateY(0); }
.success-rings { position: relative; width: 210rpx; height: 150rpx; margin-bottom: 64rpx; }
.success-rings view { position: absolute; top: 0; width: 145rpx; height: 145rpx; border: 4rpx solid rgba(248,164,168,.8); border-radius: 50%; }
.success-rings view:first-child { left: 0; }.success-rings view:nth-child(2) { right: 0; border-color: rgba(127,194,201,.8); }
.success-rings text { position: absolute; z-index: 2; left: 83rpx; top: 48rpx; color: #fff; font-size: 45rpx; text-shadow: 0 3rpx 14rpx rgba(45,42,38,.15); }
.success-kicker { color: #7FC2C9; font-size: 17rpx; letter-spacing: 5rpx; }
.success-title { margin-top: 20rpx; font-size: 42rpx; font-weight: 500; }
.success-copy { margin-top: 25rpx; color: #8D817D; font-size: 24rpx; line-height: 1.8; text-align: center; }
.finish-button { width: 100%; height: 90rpx; margin-top: 70rpx; border: 1rpx solid rgba(248,164,168,.38); border-radius: 45rpx; color: #E98E94; background: rgba(255,255,255,.5); font-size: 25rpx; backdrop-filter: blur(16px); }
