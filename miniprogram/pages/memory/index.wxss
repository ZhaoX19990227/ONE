.back{width:64rpx;height:64rpx;border-radius:50%;background:rgba(255,255,255,.55);display:flex;align-items:center;justify-content:center;font-size:50rpx}.nav-title{font-size:29rpx;font-weight:500}.nav-side{width:110rpx;text-align:right;color:var(--muted);font-size:17rpx;letter-spacing:2rpx}.filter-scroll{margin:35rpx -28rpx 4rpx;width:calc(100% + 56rpx);white-space:nowrap}.filter-row{display:flex;gap:13rpx;padding:4rpx 28rpx 18rpx}.filter{background:rgba(255,255,255,.5);color:var(--muted);border:1rpx solid rgba(154,142,138,.12)}.filter.on{background:rgba(248,164,168,.17);border-color:rgba(248,164,168,.28);color:var(--ink)}.memory-list{display:flex;flex-direction:column;gap:16rpx;margin-top:18rpx}.memory-card{position:relative;display:flex;align-items:flex-start;gap:19rpx;padding:27rpx 22rpx;border-radius:30rpx}.memory-mark{width:12rpx;height:72rpx;border-radius:10rpx;background:#F8A4A8;flex:none}.memory-mark.MILK_TEA{background:#7FC2C9}.memory-mark.COFFEE{background:#927565}.memory-main{flex:1;min-width:0}.memory-date{color:var(--muted);font-size:19rpx;letter-spacing:1rpx}.memory-text{font-size:26rpx;line-height:1.65;margin-top:8rpx}.suggestion{display:inline-flex;margin-top:12rpx;padding:7rpx 13rpx;border-radius:999rpx;background:rgba(127,194,201,.14);color:var(--secondary);font-size:19rpx}.forget{padding:8rpx;color:var(--muted);font-size:20rpx;flex:none}.memory-loading{padding:100rpx 0;text-align:center}.memory-note{text-align:center;margin:38rpx 35rpx 0;color:var(--muted);font-size:19rpx;line-height:1.7}
.toast{position:fixed;z-index:350;left:50%;top:44%;transform:translate(-50%,-50%);max-width:560rpx;padding:24rpx 34rpx;border-radius:999rpx;background:rgba(45,42,38,.9);color:white;font-size:23rpx;text-align:center;box-shadow:0 18rpx 60rpx rgba(0,0,0,.2)}
