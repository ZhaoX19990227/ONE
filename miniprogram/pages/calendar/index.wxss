.month-nav { display:flex; align-items:center; gap:24rpx; font-size:25rpx; letter-spacing:2rpx; }.month-nav text { width:55rpx; height:55rpx; display:flex; align-items:center; justify-content:center; border-radius:50%; background:rgba(255,255,255,.45); font-size:38rpx; }
.summary-card { margin-top:38rpx; padding:30rpx; border-radius:35rpx; display:flex; align-items:center; gap:20rpx; }.summary-number { font-family:"SF Pro Text"; font-size:48rpx; color:var(--primary); }.summary-number.small { font-size:31rpx; }.summary-unit { display:block; color:var(--muted); font-size:19rpx; margin-top:4rpx; }.summary-line { height:55rpx; width:1rpx; background:rgba(154,142,138,.2); }.share-button { margin:0 0 0 auto; height:66rpx; line-height:66rpx; border-radius:999rpx; border:0; padding:0 24rpx; font-size:21rpx; background:rgba(127,194,201,.15); color:var(--ink); }.share-button::after{border:0}
.budget-card{margin-top:18rpx;padding:25rpx 28rpx;border-radius:30rpx}.budget-head{display:flex;align-items:center;justify-content:space-between}.budget-label{font-size:24rpx}.budget-copy{color:var(--muted);font-size:19rpx;margin-top:7rpx}.budget-value{color:var(--primary);font-size:27rpx}.budget-track{height:9rpx;border-radius:9rpx;background:rgba(154,142,138,.12);margin-top:20rpx;overflow:hidden}.budget-progress{height:100%;border-radius:9rpx;background:linear-gradient(90deg,#7FC2C9,#F8A4A8);transition:width .6s}.budget-progress.over{background:#D9919E}
.weekly-card{margin-top:18rpx;padding:28rpx;border-radius:32rpx;position:relative;overflow:hidden;transition:transform .2s}.weekly-card:active{transform:scale(.985)}.weekly-card::after{content:"";position:absolute;width:170rpx;height:170rpx;border-radius:50%;right:-70rpx;bottom:-100rpx;background:linear-gradient(140deg,rgba(248,164,168,.18),rgba(127,194,201,.18))}.weekly-top{display:flex;justify-content:space-between;align-items:center}.weekly-kicker{color:var(--secondary);font-size:18rpx;letter-spacing:4rpx}.weekly-title{font-size:27rpx;margin-top:8rpx}.weekly-arrow{font-size:30rpx;color:var(--primary)}.weekly-message{font-size:21rpx;line-height:1.7;color:var(--muted);margin-top:18rpx}.weekly-egg{font-size:21rpx;color:var(--primary);margin-top:14rpx}.weekly-rhythm{font-size:17rpx;color:var(--muted);margin-top:17rpx}
.calendar-card { margin-top:22rpx; padding:28rpx 20rpx 22rpx; border-radius:38rpx; }.week,.grid { display:grid; grid-template-columns:repeat(7,1fr); }.week text { text-align:center; font-size:19rpx; color:var(--muted); padding-bottom:18rpx; }.day { height:82rpx; margin:3rpx; border-radius:23rpx; display:flex; flex-direction:column; align-items:center; justify-content:center; font-size:23rpx; transition:.2s; }.day.selected { background:rgba(248,164,168,.18); box-shadow:inset 0 0 0 1rpx rgba(248,164,168,.25); }.day.blank{visibility:hidden}.dots{height:9rpx;display:flex;gap:4rpx;margin-top:7rpx}.dots view{width:7rpx;height:7rpx;border-radius:50%;background:#F8A4A8}.dots .tea{background:#7FC2C9}.dots .coffee{background:#8C6D5A}.dots .deer{background:#C2A4CA}
.insight { margin-top:22rpx; padding:29rpx; border-radius:31rpx; font-size:25rpx; line-height:1.7; }.insight-label { color:var(--secondary); font-size:19rpx; letter-spacing:3rpx; margin-bottom:8rpx; }.dimension-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:12rpx}.dimension-stat{padding:22rpx 16rpx;border-radius:26rpx}.stat-dot{width:10rpx;height:10rpx;border-radius:50%;background:#F8A4A8;margin-bottom:15rpx}.stat-dot.MILK_TEA{background:#7FC2C9}.stat-dot.COFFEE{background:#8C6D5A}.stat-label{font-size:20rpx;color:var(--muted);margin-bottom:5rpx}.stat-count{font-size:32rpx}.stat-money{font-size:18rpx;margin-top:5rpx}.brand-rank{padding:6rpx 24rpx;border-radius:30rpx}.brand-row{display:flex;align-items:center;gap:14rpx;padding:17rpx 0;border-bottom:1rpx solid rgba(154,142,138,.12);font-size:23rpx}.brand-row:last-child{border:0}.rank{color:var(--muted);font-size:17rpx}.rank-logo{width:48rpx;height:48rpx;border-radius:15rpx;display:flex;align-items:center;justify-content:center;color:white;font-size:18rpx}.rank-name{flex:1}.rank-count{color:var(--muted);font-size:20rpx}.rank-amount{color:var(--primary);width:90rpx;text-align:right;font-size:20rpx}.record-list{display:flex;flex-direction:column;gap:14rpx}.record{display:flex;align-items:center;gap:17rpx;padding:18rpx;border-radius:27rpx}.record image,.mini-logo{width:76rpx;height:76rpx;border-radius:21rpx}.mini-logo{display:flex;align-items:center;justify-content:center;color:#fff;font-size:20rpx}.record-copy{flex:1;font-size:25rpx}.record-copy .muted{font-size:20rpx}.amount{color:var(--primary);font-size:23rpx}.record-more{font-size:15rpx;color:var(--muted);letter-spacing:2rpx}.day-empty{text-align:center;padding:20rpx}.poster-canvas{position:fixed;left:-9999px;top:-9999px;width:620px;height:900px}.poster-mask{position:fixed;z-index:110;inset:0;background:rgba(33,29,30,.42);backdrop-filter:blur(8rpx)}.poster-sheet{position:fixed;z-index:111;left:20rpx;right:20rpx;bottom:20rpx;padding:24rpx 25rpx calc(env(safe-area-inset-bottom) + 25rpx);border-radius:42rpx}.sheet-handle{width:68rpx;height:7rpx;border-radius:8rpx;background:rgba(154,142,138,.28);margin:0 auto 20rpx}.poster-title{text-align:center;font-size:27rpx;margin-bottom:18rpx}.poster-sheet image{display:block;width:310rpx!important;max-height:450rpx;margin:0 auto;border-radius:20rpx;box-shadow:0 12rpx 35rpx rgba(0,0,0,.12)}.poster-actions{display:flex;gap:15rpx;margin-top:24rpx}.poster-actions button{flex:1;height:78rpx;line-height:78rpx;font-size:25rpx}
