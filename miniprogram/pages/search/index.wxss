.search-page { min-height: 100vh; background: #FCF9F8; }
.search-nav { position: sticky; z-index: 5; top: 0; padding-left: 24rpx; padding-right: 30rpx; padding-bottom: 25rpx; display: flex; align-items: center; gap: 18rpx; background: rgba(252,249,248,.9); backdrop-filter: blur(18px); }
.back { width: 50rpx; font-family: serif; font-size: 52rpx; line-height: 1; }
.search-box { flex: 1; height: 78rpx; padding: 0 22rpx; display: flex; align-items: center; gap: 13rpx; border: 1rpx solid rgba(154,142,138,.13); border-radius: 39rpx; background: rgba(255,255,255,.76); }
.search-box input { flex: 1; font-size: 23rpx; }
.placeholder { color: rgba(154,142,138,.6); }
.glass { color: #7FC2C9; font-size: 32rpx; }
.clear { color: #9A8E8A; font-size: 35rpx; }
.search-content { padding: 36rpx 32rpx; }
.result-label { display: block; margin: 0 6rpx 24rpx; color: #9A8E8A; font-size: 20rpx; }
.result-card { margin-bottom: 20rpx; padding: 16rpx; display: flex; gap: 22rpx; border-radius: 26rpx; background: rgba(255,255,255,.68); box-shadow: 0 12rpx 40rpx rgba(59,45,44,.05); }
.result-cover { position: relative; width: 164rpx; height: 164rpx; flex: none; overflow: hidden; border-radius: 21rpx; }
.result-cover view { position: absolute; width: 120rpx; height: 120rpx; right: -25rpx; bottom: -30rpx; border: 2rpx solid rgba(255,255,255,.55); border-radius: 50%; }
.cover--blush { background: linear-gradient(145deg,#F8C0C2,#D8B4A8); }.cover--mist { background: linear-gradient(145deg,#9FD0D3,#8EADB6); }.cover--dusk { background: linear-gradient(145deg,#B6A8BD,#D69FA8); }.cover--sage { background: linear-gradient(145deg,#B7C5B2,#C9AB96); }
.result-copy { min-width: 0; padding: 8rpx 0; display: flex; flex-direction: column; }
.result-copy > text:first-child { overflow: hidden; font-size: 28rpx; font-weight: 500; text-overflow: ellipsis; white-space: nowrap; }
.result-copy > text:nth-child(2) { margin-top: 13rpx; color: #9A8E8A; font-size: 19rpx; }
.result-copy > view { display: flex; gap: 8rpx; margin-top: 20rpx; }
.result-copy > view text { padding: 7rpx 12rpx; border-radius: 14rpx; color: #578B90; background: rgba(127,194,201,.11); font-size: 16rpx; }
.no-result { padding-top: 180rpx; display: flex; flex-direction: column; align-items: center; gap: 16rpx; color: #9A8E8A; font-size: 21rpx; }.no-result > text:nth-child(2) { margin-top: 25rpx; color: #2D2A26; font-size: 29rpx; }
