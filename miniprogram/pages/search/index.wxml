<view class="search-page">
  <view class="search-nav safe-top">
    <text class="back" bindtap="goBack">‹</text>
    <view class="search-box"><text class="glass">⌕</text><input focus="{{focused}}" value="{{keyword}}" placeholder="想做什么，或想遇见怎样的人？" placeholder-class="placeholder" bindinput="setKeyword" /><text wx:if="{{keyword}}" class="clear" bindtap="clear">×</text></view>
  </view>
  <view class="search-content">
    <text class="result-label">{{keyword ? '找到 ' + results.length + ' 个同频信号' : '大家正在发起'}}</text>
    <view wx:for="{{results}}" wx:key="id" class="result-card" data-id="{{item.id}}" bindtap="openDetail">
      <view class="result-cover cover--{{item.theme}}"><view></view></view>
      <view class="result-copy"><text>{{item.title}}</text><text>{{item.displayTime}} · {{item.district}}</text><view><text wx:for="{{item.tags}}" wx:key="*this" wx:if="{{index < 2}}">{{item}}</text></view></view>
    </view>
    <view wx:if="{{results.length === 0}}" class="no-result"><view class="one-rings"></view><text>还没有完全相同的信号</text><text>换一个词，或者亲自发起一场吧。</text></view>
  </view>
</view>
