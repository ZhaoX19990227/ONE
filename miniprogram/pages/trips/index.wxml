<view class="page-shell trips-page">
  <view class="ambient-orb ambient-orb--blue"></view>
  <view class="trips-header safe-top">
    <text class="header-kicker">MY MOMENTS</text>
    <text class="header-title">我的行程</text>
    <view class="trip-tabs">
      <view class="trip-tab {{activeTab === 'upcoming' ? 'trip-tab--active' : ''}}" data-tab="upcoming" bindtap="setTab">即将发生</view>
      <view class="trip-tab {{activeTab === 'past' ? 'trip-tab--active' : ''}}" data-tab="past" bindtap="setTab">已经遇见</view>
    </view>
  </view>

  <view wx:if="{{activeTab === 'upcoming'}}" class="trip-content">
    <view class="date-rail"><text class="month">JUL</text><text class="day">18</text><view class="rail-line"></view></view>
    <view class="trip-card glass-card" bindtap="openDetail">
      <view class="trip-cover cover--{{activity.theme}}"><view class="cover-ring"></view><text>UPCOMING</text></view>
      <view class="trip-body">
        <text class="trip-time">{{activity.displayTime}}</text>
        <text class="trip-title">{{activity.title}}</text>
        <text class="trip-place">⌖ {{activity.district}} · 报名后可见详细位置</text>
        <view class="trip-status"><view class="status-dot"></view><text>已确认 · 开始前 30 分钟可签到</text></view>
        <button class="check-button" catchtap="checkIn">去签到</button>
      </view>
    </view>
  </view>

  <view wx:else class="empty-state">
    <view class="one-rings empty-rings"></view>
    <text class="empty-title">共同经历会留在这里</text>
    <text>完成第一场活动后，你的兴趣履历会慢慢生长。</text>
  </view>
</view>
