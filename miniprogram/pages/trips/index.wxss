.trips-page { padding-top: 1rpx; }
.trips-header { position: relative; z-index: 2; padding-left: 38rpx; padding-right: 38rpx; display: flex; flex-direction: column; }
.header-kicker { margin-top: 20rpx; color: #7FC2C9; font-size: 17rpx; letter-spacing: 5rpx; }
.header-title { margin-top: 12rpx; font-size: 47rpx; font-weight: 500; }
.trip-tabs { display: flex; gap: 42rpx; margin-top: 50rpx; border-bottom: 1rpx solid rgba(154,142,138,.14); }
.trip-tab { position: relative; padding-bottom: 20rpx; color: #9A8E8A; font-size: 24rpx; }
.trip-tab--active { color: #2D2A26; }
.trip-tab--active::after { content: ""; position: absolute; left: 0; right: 0; bottom: -1rpx; height: 3rpx; border-radius: 3rpx; background: #F8A4A8; }
.trip-content { position: relative; z-index: 2; padding: 48rpx 32rpx 0 116rpx; }
.date-rail { position: absolute; left: 36rpx; top: 48rpx; width: 58rpx; display: flex; flex-direction: column; align-items: center; }
.month { color: #F08F95; font-family: "SF Pro Text", sans-serif; font-size: 17rpx; letter-spacing: 2rpx; }
.day { margin-top: 5rpx; font-family: "SF Pro Text", sans-serif; font-size: 39rpx; }
.rail-line { width: 1rpx; height: 430rpx; margin-top: 17rpx; background: linear-gradient(#F8A4A8, rgba(248,164,168,0)); }
.trip-card { overflow: hidden; border-radius: 32rpx; }
.trip-cover { position: relative; height: 270rpx; overflow: hidden; }
.cover--blush { background: linear-gradient(145deg,#F8C0C2,#E8D1C9 55%,#D8B4A8); }
.cover-ring { position: absolute; right: -40rpx; bottom: -80rpx; width: 290rpx; height: 290rpx; border: 2rpx solid rgba(255,255,255,.58); border-radius: 50%; }
.trip-cover text { position: absolute; left: 25rpx; bottom: 20rpx; color: rgba(255,255,255,.85); font-size: 17rpx; letter-spacing: 5rpx; }
.trip-body { padding: 30rpx; display: flex; flex-direction: column; }
.trip-time { color: #F08F95; font-family: "SF Pro Text", sans-serif; font-size: 21rpx; }
.trip-title { margin-top: 12rpx; font-size: 34rpx; font-weight: 500; }
.trip-place { margin-top: 20rpx; color: #9A8E8A; font-size: 20rpx; }
.trip-status { margin-top: 30rpx; padding: 19rpx; display: flex; align-items: center; gap: 12rpx; border-radius: 20rpx; color: #577D81; background: rgba(127,194,201,.1); font-size: 19rpx; }
.status-dot { width: 9rpx; height: 9rpx; border-radius: 50%; background: #7FC2C9; box-shadow: 0 0 14rpx rgba(127,194,201,.8); }
.check-button { margin: 28rpx 0 0; height: 78rpx; border: 1rpx solid rgba(248,164,168,.4); border-radius: 39rpx; color: #F08F95; background: rgba(248,164,168,.08); font-size: 25rpx; }
.empty-state { padding: 220rpx 70rpx 0; display: flex; flex-direction: column; align-items: center; gap: 20rpx; color: #9A8E8A; font-size: 23rpx; line-height: 1.8; text-align: center; }
.empty-rings { margin-bottom: 20rpx; transform: scale(1.5); }
.empty-title { color: #2D2A26; font-size: 31rpx; }
