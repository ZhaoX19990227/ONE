.home-page { padding-top: 1rpx; }

.home-nav {
  position: relative;
  z-index: 3;
  padding-left: 36rpx;
  padding-right: 36rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.brand-block { position: relative; }
.brand-logo { font-family: Georgia, serif; font-size: 42rpx; letter-spacing: 8rpx; font-style: italic; }
.brand-dot { position: absolute; right: -2rpx; top: 6rpx; width: 7rpx; height: 7rpx; border-radius: 50%; background: #F8A4A8; }
.nav-actions { display: flex; gap: 20rpx; }

.line-icon {
  position: relative;
  width: 70rpx;
  height: 70rpx;
  border: 1rpx solid rgba(154, 142, 138, 0.16);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.58);
}

.search-icon::before { content: ""; position: absolute; left: 21rpx; top: 18rpx; width: 22rpx; height: 22rpx; border: 2rpx solid #2D2A26; border-radius: 50%; }
.search-icon::after { content: ""; position: absolute; left: 43rpx; top: 42rpx; width: 14rpx; height: 2rpx; border-radius: 2rpx; background: #2D2A26; transform: rotate(45deg); transform-origin: left center; }
.message-icon::before { content: ""; position: absolute; left: 19rpx; top: 20rpx; width: 31rpx; height: 25rpx; border: 2rpx solid #2D2A26; border-radius: 10rpx; }
.message-icon::after { content: ""; position: absolute; left: 24rpx; top: 43rpx; width: 10rpx; height: 10rpx; border-left: 2rpx solid #2D2A26; transform: skewY(-35deg); }
.message-dot { position: absolute; z-index: 2; top: 14rpx; right: 14rpx; width: 9rpx; height: 9rpx; border: 3rpx solid #FCF9F8; border-radius: 50%; background: #F8A4A8; }

.greeting-block { position: relative; z-index: 2; padding: 64rpx 36rpx 34rpx; display: flex; flex-direction: column; }
.city-picker { display: flex; align-items: center; width: max-content; gap: 8rpx; margin-bottom: 20rpx; color: #9A8E8A; font-size: 24rpx; }
.chevron { font-size: 30rpx; transform: translateY(-3rpx); }
.greeting-title { font-size: 48rpx; font-weight: 500; letter-spacing: 1rpx; }
.greeting-subtitle { margin-top: 14rpx; color: #9A8E8A; font-size: 24rpx; letter-spacing: 2rpx; }

.filter-scroll { position: relative; z-index: 2; width: 100%; margin-bottom: 32rpx; white-space: nowrap; }
.filter-row { display: flex; gap: 16rpx; padding: 0 36rpx; }
.filter-pill { flex: none; padding: 17rpx 30rpx; border: 1rpx solid rgba(154,142,138,.13); border-radius: 34rpx; color: #9A8E8A; background: rgba(255,255,255,.55); font-size: 24rpx; transition: all 160ms ease; }
.filter-pill--active { color: #fff; border-color: transparent; background: #F8A4A8; box-shadow: 0 10rpx 24rpx rgba(248,164,168,.24); }

.loading-state { padding-top: 140rpx; display: flex; flex-direction: column; align-items: center; gap: 26rpx; color: #9A8E8A; font-size: 24rpx; }
.loading-rings { animation: float 2s ease-in-out infinite; }
@keyframes float { 50% { transform: translateY(-10rpx); } }

.activity-grid { position: relative; z-index: 2; padding: 0 28rpx 48rpx; display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); align-items: start; gap: 22rpx; }
.activity-card { min-width: 0; overflow: hidden; border-radius: 30rpx; transition: transform 160ms ease, box-shadow 160ms ease; }
.activity-card--hover { transform: translateY(-8rpx) scale(.99); box-shadow: 0 22rpx 58rpx rgba(59,45,44,.1); }
.activity-cover { position: relative; height: 280rpx; overflow: hidden; }
.cover-size--1 { height: 340rpx; }
.cover-size--2 { height: 300rpx; }
.cover--blush { background: linear-gradient(145deg, #F8C0C2, #E8D1C9 55%, #D8B4A8); }
.cover--mist { background: linear-gradient(145deg, #9FD0D3, #B8CACD 55%, #8EADB6); }
.cover--dusk { background: linear-gradient(145deg, #B6A8BD, #D6BFC4 48%, #D69FA8); }
.cover--sage { background: linear-gradient(145deg, #B7C5B2, #D7CEB8 55%, #C9AB96); }
.cover-ring { position: absolute; border: 2rpx solid rgba(255,255,255,.6); border-radius: 50%; }
.cover-ring--one { width: 190rpx; height: 190rpx; right: -30rpx; bottom: -20rpx; }
.cover-ring--two { width: 118rpx; height: 118rpx; right: 90rpx; bottom: 42rpx; border-color: rgba(255,255,255,.4); }
.cover-badge { position: absolute; top: 18rpx; left: 18rpx; padding: 9rpx 17rpx; border-radius: 22rpx; color: #fff; background: rgba(248,164,168,.88); backdrop-filter: blur(10px); font-size: 18rpx; }
.cover-type { position: absolute; right: 18rpx; bottom: 17rpx; color: rgba(255,255,255,.83); font-family: "SF Pro Text", sans-serif; font-size: 18rpx; letter-spacing: 4rpx; }

.card-content { padding: 24rpx 22rpx 22rpx; }
.activity-time { display: block; margin-bottom: 10rpx; color: #F08F95; font-family: "SF Pro Text", sans-serif; font-size: 20rpx; }
.activity-title { display: -webkit-box; overflow: hidden; min-height: 76rpx; font-size: 29rpx; font-weight: 500; line-height: 1.35; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.tag-row { display: flex; flex-wrap: wrap; gap: 8rpx; margin-top: 16rpx; }
.mini-tag { padding: 7rpx 12rpx; border-radius: 16rpx; color: #598B90; background: rgba(127,194,201,.13); font-size: 17rpx; }
.place-row { display: flex; align-items: center; gap: 8rpx; margin-top: 17rpx; color: #9A8E8A; font-size: 19rpx; }
.place-dot { width: 8rpx; height: 8rpx; border: 2rpx solid #7FC2C9; border-radius: 50%; }
.deposit-line { display: flex; gap: 7rpx; margin-top: 14rpx; color: #806F69; font-family: "SF Pro Text", sans-serif; font-size: 19rpx; }
.card-footer { margin-top: 22rpx; padding-top: 17rpx; border-top: 1rpx solid rgba(154,142,138,.12); display: flex; align-items: center; justify-content: space-between; }
.host-mini { display: flex; min-width: 0; align-items: center; gap: 8rpx; color: #9A8E8A; font-size: 17rpx; }
.host-mini text { overflow: hidden; max-width: 110rpx; text-overflow: ellipsis; white-space: nowrap; }
.host-avatar { width: 34rpx; height: 34rpx; display: flex; align-items: center; justify-content: center; border: 2rpx solid rgba(248,164,168,.55); border-radius: 50%; color: #fff; background: #A9A0AA; font-size: 15rpx; }
.capacity { color: #9A8E8A; font-family: "SF Pro Text", sans-serif; font-size: 20rpx; }
.capacity-current { color: #F08F95; font-size: 27rpx; }

.sheet-mask { position: fixed; z-index: 199; inset: 0; background: rgba(45,42,38,.22); backdrop-filter: blur(4rpx); }
.city-sheet { position: fixed; z-index: 200; left: 0; right: 0; bottom: 0; padding: 18rpx 40rpx calc(48rpx + env(safe-area-inset-bottom)); border-radius: 42rpx 42rpx 0 0; background: #FCF9F8; transform: translateY(110%); transition: transform 260ms cubic-bezier(.22,.8,.28,1); }
.city-sheet--visible { transform: translateY(0); }
.sheet-handle { width: 72rpx; height: 7rpx; margin: 0 auto 38rpx; border-radius: 6rpx; background: rgba(154,142,138,.25); }
.sheet-title { display: block; margin-bottom: 24rpx; font-size: 32rpx; font-weight: 500; }
.city-option { height: 92rpx; padding: 0 8rpx; display: flex; align-items: center; justify-content: space-between; border-bottom: 1rpx solid rgba(154,142,138,.13); color: #655D59; }
.city-option--active { color: #F08F95; }
.city-note { display: block; margin-top: 28rpx; color: #9A8E8A; font-size: 20rpx; text-align: center; }
