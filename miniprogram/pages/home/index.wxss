.today-dot { font-size:20rpx; letter-spacing:5rpx; color:var(--muted); }
.dimension-switch { margin-top:38rpx; padding:10rpx; border-radius:30rpx; display:flex; position:relative; z-index:2; }
.dimension { flex:1; height:102rpx; border-radius:23rpx; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:5rpx; color:var(--muted); font-size:23rpx; transition:all .25s; }
.dimension.active { background:rgba(255,255,255,.8); color:var(--ink); box-shadow:0 8rpx 24rpx rgba(55,42,42,.07); }
.theme-night .dimension.active { background:rgba(255,255,255,.12); }
.d-icon { font-size:34rpx; color:var(--accent); font-weight:300; }
.drink-toggle { display:flex; justify-content:center; gap:14rpx; margin:24rpx 0 -5rpx; }
.drink-toggle .pill { background:rgba(255,255,255,.45); color:var(--muted); }
.drink-toggle .on { background:rgba(127,194,201,.18); color:var(--ink); }
.hero-card { position:relative; z-index:2; margin-top:34rpx; padding:42rpx 34rpx 32rpx; border-radius:42rpx; overflow:hidden; }
.hero-card::after { content:""; position:absolute; width:250rpx; height:250rpx; border-radius:50%; right:-130rpx; top:-100rpx; background:linear-gradient(140deg,var(--wash-a),var(--wash-b)); opacity:.65; }
.hero-kicker,.sheet-kicker { color:var(--accent); font-size:20rpx; letter-spacing:5rpx; margin-bottom:14rpx; }
.hero-title { font-size:36rpx; line-height:1.45; font-weight:500; max-width:560rpx; }
.hero-copy { color:var(--muted); font-size:24rpx; line-height:1.8; margin:14rpx 0 32rpx; }
.hero-actions { display:flex; gap:18rpx; margin-top:18rpx; }
.hero-actions button { flex:1; }
.record-list { display:flex; flex-direction:column; gap:16rpx; }
.record-row { padding:20rpx; border-radius:28rpx; display:flex; align-items:center; gap:20rpx; }
.thumb,.brand-mark { width:86rpx; height:86rpx; border-radius:24rpx; flex:none; }
.brand-mark { display:flex; align-items:center; justify-content:center; color:white; font-size:24rpx; }
.record-main { flex:1; min-width:0; }.record-title { font-size:27rpx; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }.line { font-size:21rpx; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }.price { font-size:25rpx; color:var(--primary); }
.mask { position:fixed; z-index:110; inset:0; background:rgba(33,29,30,.35); backdrop-filter:blur(8rpx); }
.recommend-sheet { position:fixed; z-index:111; left:18rpx; right:18rpx; bottom:18rpx; max-height:83vh; padding:34rpx 28rpx calc(env(safe-area-inset-bottom) + 28rpx); border-radius:48rpx; box-sizing:border-box; overflow-y:auto; }
.sheet-handle { width:70rpx; height:7rpx; border-radius:9rpx; background:rgba(154,142,138,.32); margin:0 auto 28rpx; }.sheet-close { position:absolute; right:32rpx; top:28rpx; font-size:42rpx; color:var(--muted); }.sheet-title { font-size:34rpx; line-height:1.5; font-weight:500; }
.wheel-wrap { width:300rpx; height:300rpx; margin:22rpx auto; position:relative; }.wheel { width:100%; height:100%; border-radius:50%; background:conic-gradient(#F8A4A8 0 45deg,#F4D3D0 45deg 90deg,#7FC2C9 90deg 135deg,#D7E9E7 135deg 180deg,#E5B7BD 180deg 225deg,#F1DFD7 225deg 270deg,#91C9CD 270deg 315deg,#F8C4BA 315deg); box-shadow:0 15rpx 45rpx rgba(61,44,44,.14); transition:transform 1.6s cubic-bezier(.12,.72,.18,1); display:flex; align-items:center; justify-content:center; }.wheel-core { width:132rpx; height:132rpx; border-radius:50%; background:rgba(255,255,255,.9); display:flex; flex-direction:column; align-items:center; justify-content:center; color:#2D2A26; font-size:21rpx; letter-spacing:3rpx; }.rings.small { transform:scale(.55); height:38rpx; margin:-8rpx 0 5rpx; }.wheel-pointer { position:absolute; z-index:3; top:-8rpx; left:138rpx; color:#2D2A26; font-size:30rpx; }
.candidate-list { display:flex; flex-direction:column; gap:13rpx; }.candidate { display:flex; align-items:center; gap:16rpx; padding:17rpx; border-radius:25rpx; border:2rpx solid transparent; background:rgba(255,255,255,.55); transition:all .2s; }.candidate.selected { border-color:var(--primary); transform:translateY(-3rpx); box-shadow:0 10rpx 30rpx rgba(248,164,168,.14); }.tiny { width:68rpx; height:68rpx; border-radius:20rpx; font-size:20rpx; }.candidate-copy { flex:1; min-width:0; font-size:26rpx; }.candidate-price { color:var(--primary); font-size:23rpx; }.join { margin-top:22rpx; }
.toast { position:fixed; z-index:200; left:50%; top:44%; transform:translate(-50%,-50%); max-width:560rpx; padding:26rpx 38rpx; border-radius:999rpx; background:rgba(45,42,38,.88); color:white; font-size:25rpx; text-align:center; box-shadow:0 18rpx 60rpx rgba(0,0,0,.2); }
.petals { position:fixed; z-index:190; inset:0; pointer-events:none; }.petal { position:absolute; top:38%; left:50%; width:22rpx; height:38rpx; border-radius:80% 20% 70% 30%; background:rgba(248,164,168,.65); animation:fall 2s ease-out forwards; }.p1{margin-left:-160rpx;background:rgba(127,194,201,.6)}.p2{margin-left:-80rpx;animation-delay:.1s}.p3{margin-left:10rpx;background:rgba(228,199,200,.8);animation-delay:.2s}.p4{margin-left:90rpx;animation-delay:.05s}.p5{margin-left:150rpx;background:rgba(127,194,201,.65);animation-delay:.15s}
@keyframes fall { 0%{transform:translateY(-80rpx) rotate(0);opacity:0} 20%{opacity:1} 100%{transform:translateY(520rpx) rotate(280deg);opacity:0} }
