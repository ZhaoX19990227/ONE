.profile-page { padding-top: 1rpx; }
.profile-hero { position: relative; height: 590rpx; overflow: hidden; background: linear-gradient(155deg,#F6D1D2 0%,#E9D6D4 50%,#C4DCDD 100%); }
.hero-orb { position: absolute; border: 2rpx solid rgba(255,255,255,.5); border-radius: 50%; }
.hero-orb--one { width: 480rpx; height: 480rpx; left: -210rpx; top: 190rpx; }
.hero-orb--two { width: 390rpx; height: 390rpx; right: -160rpx; top: 80rpx; }
.profile-nav { position: relative; z-index: 2; padding-left: 36rpx; padding-right: 36rpx; display: flex; justify-content: space-between; color: rgba(45,42,38,.65); font-family: "SF Pro Text", sans-serif; font-size: 18rpx; letter-spacing: 5rpx; }
.setting-icon { width: 68rpx; height: 50rpx; display: flex; justify-content: flex-end; font-size: 35rpx; letter-spacing: 2rpx; }
.identity-block { position: relative; z-index: 2; margin-top: 58rpx; display: flex; flex-direction: column; align-items: center; }
.avatar-rings { position: relative; width: 170rpx; height: 170rpx; display: flex; align-items: center; justify-content: center; border: 3rpx solid rgba(248,164,168,.7); border-radius: 50%; }
.avatar-rings::after { content: ""; position: absolute; width: 170rpx; height: 170rpx; left: 12rpx; top: -9rpx; border: 3rpx solid rgba(127,194,201,.7); border-radius: 50%; }
.avatar-core { position: relative; z-index: 2; width: 142rpx; height: 142rpx; display: flex; align-items: center; justify-content: center; border: 5rpx solid rgba(255,255,255,.7); border-radius: 50%; color: #fff; background: linear-gradient(145deg,#998D99,#6F8588); font-size: 46rpx; }
.profile-name { margin-top: 25rpx; font-size: 36rpx; font-weight: 500; }
.profile-bio { margin-top: 10rpx; color: rgba(45,42,38,.58); font-size: 22rpx; }
.identity-badges { display: flex; gap: 12rpx; margin-top: 21rpx; }
.identity-badges text { padding: 8rpx 15rpx; border: 1rpx solid rgba(255,255,255,.5); border-radius: 18rpx; color: rgba(45,42,38,.65); background: rgba(255,255,255,.24); font-size: 17rpx; }
.profile-content { position: relative; z-index: 3; margin-top: -56rpx; padding: 0 30rpx 30rpx; }
.record-card { padding: 28rpx 10rpx; border-radius: 30rpx; display: grid; grid-template-columns: repeat(3,1fr); }
.record-item { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.record-item + .record-item { border-left: 1rpx solid rgba(154,142,138,.15); }
.record-item text:first-child { font-family: "SF Pro Text", sans-serif; font-size: 34rpx; }
.record-item text:last-child { color: #9A8E8A; font-size: 18rpx; }
.profile-section { margin-top: 52rpx; }
.section-head { padding: 0 7rpx; display: flex; align-items: flex-end; justify-content: space-between; }
.section-head > view { display: flex; flex-direction: column; gap: 8rpx; }
.section-kicker { color: #7FC2C9; font-size: 16rpx; letter-spacing: 4rpx; }
.section-title { font-size: 32rpx; font-weight: 500; }
.edit-link { color: #F08F95; font-size: 21rpx; }
.passport-card { position: relative; overflow: hidden; margin-top: 23rpx; padding: 30rpx; border-radius: 30rpx; color: #5D5551; background: linear-gradient(145deg,rgba(255,255,255,.82),rgba(248,232,230,.66)); box-shadow: 0 16rpx 50rpx rgba(59,45,44,.06); }
.passport-card::after { content: ""; position: absolute; right: -90rpx; top: -70rpx; width: 230rpx; height: 230rpx; border: 2rpx solid rgba(248,164,168,.25); border-radius: 50%; }
.passport-mark { display: flex; align-items: center; justify-content: space-between; color: #9A8E8A; font-size: 16rpx; letter-spacing: 3rpx; }
.passport-mark .one-rings { transform: scale(.55); transform-origin: left center; }
.tag-cloud { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 22rpx; }
.tag-cloud text { padding: 12rpx 18rpx; border-radius: 21rpx; color: #567C80; background: rgba(127,194,201,.12); font-size: 20rpx; }
.availability { margin-top: 28rpx; padding-top: 22rpx; display: flex; justify-content: space-between; border-top: 1rpx dashed rgba(154,142,138,.25); color: #9A8E8A; font-size: 19rpx; }
.availability text:last-child { color: #655D59; }
.menu-section { overflow: hidden; border-radius: 28rpx; background: rgba(255,255,255,.62); }
.menu-row { height: 98rpx; padding: 0 26rpx; display: flex; align-items: center; justify-content: space-between; color: #9A8E8A; }
.menu-row + .menu-row { border-top: 1rpx solid rgba(154,142,138,.11); }
.menu-row > view { display: flex; align-items: center; gap: 20rpx; color: #4F4946; font-size: 24rpx; }
.menu-icon { width: 34rpx; color: #F08F95; font-family: "SF Pro Text", sans-serif; font-size: 28rpx; text-align: center; }
.profile-footnote { display: block; padding: 50rpx 0 15rpx; color: #B6ABA7; font-size: 19rpx; letter-spacing: 2rpx; text-align: center; }
