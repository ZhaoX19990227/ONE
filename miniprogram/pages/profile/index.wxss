.privacy-pill { padding:11rpx 18rpx; border-radius:999rpx; color:var(--secondary); background:rgba(127,194,201,.12); font-size:19rpx; }.profile-head { margin-top:30rpx; display:flex; align-items:center; gap:28rpx; }.avatar-button { margin:0; padding:0; width:142rpx; height:142rpx; border-radius:50%; border:5rpx solid rgba(248,164,168,.45); background:linear-gradient(145deg,#F8A4A8,#7FC2C9); color:white; font-size:48rpx; overflow:visible; display:flex; align-items:center; justify-content:center; box-shadow:0 15rpx 38rpx rgba(248,164,168,.2); }.avatar-button::after{border:0}.avatar-button image{width:100%;height:100%;border-radius:50%}.avatar-button text{position:absolute;right:-2rpx;bottom:3rpx;width:39rpx;height:39rpx;border-radius:50%;background:#fff;color:#F8A4A8;font-size:26rpx;line-height:39rpx;box-shadow:0 5rpx 15rpx rgba(0,0,0,.12)}.name-wrap{flex:1}.name-wrap input{height:65rpx;font-size:37rpx;font-weight:500;color:var(--ink);}.name-wrap .muted{font-size:21rpx}
.form-card{border-radius:38rpx;padding:0 30rpx}.inline-field,.role-field{min-height:112rpx;padding:22rpx 0;box-sizing:border-box;border-bottom:1rpx solid rgba(154,142,138,.16);display:flex;align-items:center;justify-content:space-between;font-size:26rpx}.inline-field:last-child,.role-field:last-child{border:0}.inline-field .muted,.role-field .muted{font-size:19rpx;line-height:1.5}.unit-input{display:flex;align-items:center;gap:7rpx;color:var(--muted);font-size:22rpx}.unit-input input{width:100rpx;text-align:right;font-size:29rpx;color:var(--ink)}.unit-input.budget input{width:130rpx}.role-field{align-items:flex-start;flex-direction:column;gap:20rpx}.role-row{display:flex;width:100%;gap:12rpx}.role{flex:1;height:65rpx;border-radius:20rpx;background:rgba(255,255,255,.5);display:flex;align-items:center;justify-content:center;color:var(--muted);font-size:24rpx;border:1rpx solid rgba(154,142,138,.12)}.role.on{background:rgba(248,164,168,.17);color:var(--ink);border-color:rgba(248,164,168,.3)}
.tag-row{display:flex;flex-wrap:wrap;gap:14rpx}.tag{background:rgba(255,255,255,.52);border:1rpx solid rgba(154,142,138,.12);color:var(--muted)}.tag.on{background:rgba(127,194,201,.16);border-color:rgba(127,194,201,.3);color:var(--ink)}.save{margin-top:45rpx}.privacy-note{text-align:center;color:var(--muted);font-size:20rpx;line-height:1.7;margin:45rpx 40rpx 5rpx}.privacy-note .rings{transform:scale(.65);margin-bottom:8rpx}.toast{position:fixed;z-index:200;left:50%;top:45%;transform:translate(-50%,-50%);padding:25rpx 38rpx;border-radius:999rpx;background:rgba(45,42,38,.9);color:white;font-size:24rpx;white-space:nowrap}
