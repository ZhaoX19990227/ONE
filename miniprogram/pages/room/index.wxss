.room-nav{display:flex;align-items:center;justify-content:space-between;padding-top:14rpx;position:relative;z-index:2}.back,.share{width:68rpx;height:68rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,.52);font-size:36rpx}.room-code{font-size:19rpx;letter-spacing:4rpx;color:var(--muted)}.room-head{margin:56rpx 4rpx 34rpx;position:relative;z-index:2}.eyebrow{font-size:19rpx;letter-spacing:5rpx;color:var(--accent);margin-bottom:12rpx}.candidate-grid{display:grid;grid-template-columns:1fr 1fr;gap:18rpx;position:relative;z-index:2}.room-card{min-height:260rpx;border-radius:36rpx;padding:28rpx 22rpx;box-sizing:border-box;position:relative;overflow:hidden;border:2rpx solid transparent;transition:transform .24s,border-color .24s,box-shadow .24s}.room-card:active{transform:scale(.97)}.room-card.mine{border-color:var(--secondary);box-shadow:0 12rpx 35rpx rgba(127,194,201,.14)}.room-card.winner{grid-column:1 / 3;border-color:var(--primary);animation:winner-in .55s cubic-bezier(.2,.8,.2,1)}.winner-badge{position:absolute;right:18rpx;top:18rpx;padding:7rpx 15rpx;border-radius:999rpx;background:var(--primary);color:white;font-size:18rpx}.brand-orb{width:78rpx;height:78rpx;border-radius:25rpx;display:flex;align-items:center;justify-content:center;color:white;font-size:20rpx;box-shadow:0 8rpx 22rpx rgba(45,42,38,.1)}.item-name{font-size:25rpx;line-height:1.55;margin:20rpx 0 24rpx;min-height:76rpx}.vote-line{display:flex;gap:10rpx;align-items:center;color:var(--muted);font-size:18rpx}.vote-track{height:7rpx;flex:1;background:rgba(154,142,138,.14);border-radius:99rpx;overflow:hidden}.vote-fill{height:100%;background:linear-gradient(90deg,var(--secondary),var(--primary));border-radius:99rpx;transition:width .5s cubic-bezier(.2,.8,.2,1)}.vote-state{font-size:17rpx;color:var(--muted);margin-top:13rpx}.privacy-note{text-align:center;color:var(--muted);font-size:20rpx;line-height:1.7;margin:32rpx 36rpx 180rpx}.bottom-actions{position:fixed;z-index:10;left:24rpx;right:24rpx;bottom:calc(env(safe-area-inset-bottom) + 24rpx);display:flex;gap:16rpx;padding:16rpx;border-radius:34rpx;background:rgba(252,249,248,.8);backdrop-filter:blur(20rpx);box-shadow:0 12rpx 42rpx rgba(45,42,38,.1)}.bottom-actions button{flex:1;margin:0}.toast{position:fixed;z-index:200;left:50%;top:44%;transform:translate(-50%,-50%);padding:24rpx 34rpx;border-radius:999rpx;background:rgba(45,42,38,.9);color:white;font-size:23rpx;white-space:nowrap}@keyframes winner-in{0%{transform:scale(.94);opacity:.5}65%{transform:scale(1.025)}100%{transform:scale(1);opacity:1}}
