.publish-page { padding-top: 1rpx; }
.publish-nav { position: relative; z-index: 2; padding-left: 38rpx; padding-right: 38rpx; display: flex; align-items: flex-end; justify-content: space-between; }
.publish-nav > view:first-child { display: flex; flex-direction: column; }
.nav-eyebrow { margin-bottom: 12rpx; color: #7FC2C9; font-size: 17rpx; letter-spacing: 5rpx; }
.nav-title { font-size: 45rpx; font-weight: 500; }
.mini-rings { transform: scale(.72); transform-origin: right bottom; }
.form-wrap { position: relative; z-index: 2; padding: 48rpx 36rpx; }
.mode-switch { display: grid; grid-template-columns: 1fr 1fr; padding: 7rpx; border-radius: 40rpx; background: rgba(154,142,138,.09); }
.mode-option { height: 66rpx; display: flex; align-items: center; justify-content: center; border-radius: 34rpx; color: #9A8E8A; font-size: 24rpx; transition: all 180ms ease; }
.mode-option--active { color: #2D2A26; background: rgba(255,255,255,.92); box-shadow: 0 8rpx 24rpx rgba(59,45,44,.07); }
.form-section { position: relative; margin-top: 60rpx; }
.section-number { margin-right: 14rpx; color: #F8A4A8; font-family: "SF Pro Text", sans-serif; font-size: 19rpx; }
.section-title { font-size: 31rpx; font-weight: 500; }
.line-field { min-height: 116rpx; padding: 27rpx 4rpx 18rpx; display: flex; flex-direction: column; gap: 11rpx; border-bottom: 1rpx solid rgba(154,142,138,.23); }
.line-field:focus-within { border-bottom-color: #F8A4A8; }
.field-label { color: #9A8E8A; font-size: 19rpx; }
.line-field input, .line-field textarea { width: 100%; color: #2D2A26; font-size: 27rpx; line-height: 1.7; }
.placeholder { color: rgba(154,142,138,.55); }
.picker-field { position: relative; }
.field-arrow { position: absolute; right: 6rpx; bottom: 20rpx; color: #9A8E8A; font-size: 30rpx; }
.textarea-field { position: relative; padding-bottom: 42rpx; }
.counter { position: absolute; right: 2rpx; bottom: 9rpx; color: #B6ABA7; font-family: "SF Pro Text", sans-serif; font-size: 17rpx; }
.field-pair { display: grid; grid-template-columns: 1fr 1fr; gap: 34rpx; }
.compact-field { min-width: 0; }
.slider-section slider { margin: 18rpx -4rpx 0; }
.slider-head { margin-top: 36rpx; display: flex; align-items: center; justify-content: space-between; font-size: 25rpx; }
.slider-value { color: #578B90; font-family: "SF Pro Text", sans-serif; font-size: 29rpx; }
.deposit-head { margin-top: 54rpx; align-items: flex-start; }
.deposit-head > view { display: flex; flex-direction: column; gap: 7rpx; }
.slider-help { color: #9A8E8A; font-size: 18rpx; }
.deposit-value { color: #F08F95; font-family: "SF Pro Text", sans-serif; font-size: 36rpx; }
.switch-row { margin-top: 50rpx; padding: 26rpx 0; display: flex; align-items: center; justify-content: space-between; border-top: 1rpx solid rgba(154,142,138,.15); border-bottom: 1rpx solid rgba(154,142,138,.15); }
.switch-row > view { display: flex; flex-direction: column; gap: 8rpx; }
.switch-row > view > text:last-child { color: #9A8E8A; font-size: 18rpx; }
.privacy-hint { margin: 52rpx 8rpx 26rpx; display: flex; gap: 14rpx; color: #9A8E8A; font-size: 20rpx; line-height: 1.7; }
.privacy-hint > text:first-child { color: #7FC2C9; }
.publish-button { margin: 0; border: 0; }
