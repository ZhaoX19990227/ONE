.one-overlay-mask{position:fixed;z-index:320;inset:0;background:rgba(33,29,30,.38);-webkit-backdrop-filter:blur(7rpx);backdrop-filter:blur(7rpx)}
.one-dialog{position:fixed;z-index:321;left:62rpx;right:62rpx;top:50%;transform:translateY(-50%);padding:42rpx 34rpx 28rpx;border-radius:42rpx;background:rgba(255,255,255,.94);border:1rpx solid rgba(255,255,255,.62);box-shadow:0 28rpx 90rpx rgba(38,28,31,.2);color:#2D2A26;text-align:center;animation:dialog-in .3s cubic-bezier(.2,.75,.25,1) both}
.one-dialog-rings{position:relative;width:70rpx;height:44rpx;margin:0 auto 22rpx}.one-dialog-rings view{position:absolute;width:40rpx;height:40rpx;border:2rpx solid #F8A4A8;border-radius:50%}.one-dialog-rings view:last-child{left:26rpx;border-color:#7FC2C9}
.one-dialog-title{font-size:31rpx;font-weight:500;line-height:1.5}.one-dialog-content{margin:15rpx 4rpx 30rpx;color:#9A8E8A;font-size:24rpx;line-height:1.75}
.one-dialog-actions{display:flex;gap:15rpx;margin-top:30rpx}.one-dialog-button{flex:1;height:78rpx;margin:0;border:0;border-radius:999rpx;font-size:26rpx;line-height:78rpx}.one-dialog-button::after{border:0}.cancel{background:rgba(127,194,201,.12);color:#5F5552}.confirm{background:linear-gradient(120deg,#F8A4A8,#E4C7C8);color:white;box-shadow:0 12rpx 28rpx rgba(248,164,168,.22)}.danger{background:linear-gradient(120deg,#D9919E,#C67F8D)}
.one-dialog-button:active{transform:scale(.97)}
@keyframes dialog-in{from{opacity:0;transform:translateY(-46%) scale(.96)}to{opacity:1;transform:translateY(-50%) scale(1)}}
