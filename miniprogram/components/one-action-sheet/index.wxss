.one-overlay-mask{position:fixed;z-index:320;inset:0;background:rgba(33,29,30,.38);-webkit-backdrop-filter:blur(7rpx);backdrop-filter:blur(7rpx)}
.one-action-sheet{position:fixed;z-index:321;left:18rpx;right:18rpx;bottom:18rpx;padding:22rpx 24rpx calc(env(safe-area-inset-bottom) + 22rpx);border-radius:46rpx;background:rgba(255,255,255,.94);border:1rpx solid rgba(255,255,255,.62);box-shadow:0 28rpx 90rpx rgba(38,28,31,.2);color:#2D2A26}
.one-sheet-handle{width:68rpx;height:7rpx;border-radius:8rpx;background:rgba(154,142,138,.28);margin:0 auto 22rpx}.one-sheet-title{text-align:center;color:#9A8E8A;font-size:22rpx;line-height:1.6;margin:0 20rpx 14rpx}
.one-sheet-items{overflow:hidden;border-radius:28rpx;background:rgba(252,249,248,.86)}.one-sheet-item{height:91rpx;line-height:91rpx;text-align:center;font-size:27rpx;border-bottom:1rpx solid rgba(154,142,138,.13)}.one-sheet-item:last-child{border:0}.one-sheet-item:active{background:rgba(127,194,201,.13)}.one-sheet-item.danger{color:#C97584}
.one-sheet-cancel{height:82rpx;margin-top:16rpx;border-radius:999rpx;background:rgba(127,194,201,.12);text-align:center;line-height:82rpx;font-size:26rpx}.one-sheet-cancel:active{transform:scale(.985)}
