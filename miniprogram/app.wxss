page { --ink:#2D2A26; --muted:#9A8E8A; --primary:#F8A4A8; --secondary:#7FC2C9; background:#FCF9F8; color:var(--ink); font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","SF Pro Text",sans-serif; font-weight:400; }
.page { min-height:100vh; box-sizing:border-box; padding:calc(env(safe-area-inset-top) + 30rpx) 28rpx 190rpx; position:relative; overflow:hidden; }
.theme-morning { --wash-a:#FFE9D8; --wash-b:#F8D9D4; --accent:#F39C8E; background:linear-gradient(155deg,#FFF9F0 0%,#FCF9F8 55%,#F3FBF8 100%); }
.theme-noon { --wash-a:#F8DCDD; --wash-b:#DCEEEF; --accent:#F8A4A8; background:linear-gradient(155deg,#FFF7F6 0%,#FCF9F8 50%,#EFF8F8 100%); }
.theme-evening { --wash-a:#E8CED5; --wash-b:#C8DCE1; --accent:#D9919E; background:linear-gradient(155deg,#F9EFF0 0%,#F7F3F2 52%,#EDF4F5 100%); }
.theme-night { --ink:#F7F0ED; --muted:#B9ACAA; --wash-a:#594A59; --wash-b:#334B55; --accent:#E6A2AA; background:linear-gradient(155deg,#27242B 0%,#302A31 52%,#26363C 100%); }
.orb { position:absolute; border-radius:50%; filter:blur(6rpx); opacity:.65; pointer-events:none; }
.orb-a { width:420rpx; height:420rpx; background:var(--wash-a); top:-210rpx; right:-140rpx; }
.orb-b { width:300rpx; height:300rpx; background:var(--wash-b); top:420rpx; left:-190rpx; opacity:.38; }
.glass { background:rgba(255,255,255,.68); border:1rpx solid rgba(255,255,255,.48); box-shadow:0 18rpx 60rpx rgba(63,45,45,.07); backdrop-filter:blur(20px); }
.theme-night .glass { background:rgba(255,255,255,.09); border-color:rgba(255,255,255,.13); box-shadow:0 18rpx 60rpx rgba(0,0,0,.18); }
.nav { display:flex; align-items:center; justify-content:space-between; height:92rpx; position:relative; z-index:2; }
.logo { font-size:46rpx; letter-spacing:8rpx; font-weight:500; }
.logo-dot { width:12rpx; height:12rpx; display:inline-block; background:var(--primary); border-radius:50%; margin-left:4rpx; box-shadow:0 0 0 8rpx rgba(248,164,168,.14); }
.headline { font-size:42rpx; line-height:1.45; font-weight:500; margin:28rpx 0 8rpx; }
.muted { color:var(--muted); font-size:25rpx; line-height:1.8; }
.pill { display:inline-flex; align-items:center; padding:13rpx 22rpx; border-radius:999rpx; font-size:24rpx; }
.primary-btn { height:92rpx; border:0; border-radius:999rpx; color:white; font-weight:500; font-size:29rpx; line-height:92rpx; background:linear-gradient(120deg,#F8A4A8,#E4C7C8); box-shadow:0 16rpx 34rpx rgba(248,164,168,.28); }
.primary-btn::after,.ghost-btn::after { border:0; }
.primary-btn:active { transform:scale(.97); }
.ghost-btn { height:82rpx; border:1rpx solid rgba(127,194,201,.28); border-radius:999rpx; background:rgba(127,194,201,.12); color:var(--ink); font-size:27rpx; line-height:82rpx; }
.section-title { font-size:30rpx; font-weight:500; margin:44rpx 0 22rpx; }
.empty { text-align:center; padding:70rpx 30rpx; color:var(--muted); font-size:25rpx; }
.rings { position:relative; width:96rpx; height:62rpx; margin:0 auto 24rpx; }
.rings::before,.rings::after { content:""; position:absolute; width:58rpx; height:58rpx; border:3rpx solid var(--primary); border-radius:50%; }
.rings::after { left:34rpx; border-color:var(--secondary); }
